<Window x:Class="TudfConverter.WpfUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="TUDF Converter"
        Height="700" Width="1000"
        MinHeight="600" MinWidth="800"
        Background="{StaticResource AppBackground}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Plus Jakarta Sans, Inter, SF Pro Display, Segoe UI, sans-serif"
        RenderOptions.BitmapScalingMode="HighQuality"
        TextOptions.TextRenderingMode="ClearType">

    <!-- ═══════════════════════════════════
         ROOT: 3 rows — TopNav | Body | Footer
    ═══════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <!-- Top navigation bar   -->
            <RowDefinition Height="*"/>
            <!-- Main content area    -->
            <RowDefinition Height="38"/>
            <!-- Footer bar           -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════
             ROW 0 · TOP NAVIGATION BAR
        ══════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource TopNavStyle}">
            <Grid Margin="24,0">

                <!-- Left: Logo badge + app name -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- TC badge -->
                    <Border Style="{StaticResource LogoBadgeStyle}" Margin="0,0,10,0">
                        <TextBlock Text="TC"
                                   Foreground="{StaticResource PrimaryAccent}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- App name -->
                    <TextBlock Text="TUDF Converter"
                               Style="{StaticResource H3Style}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: status pill + date -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <!-- "Ready" status pill -->
                    <Border Style="{StaticResource StatusPillStyle}" Margin="0,0,14,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Green dot -->
                            <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,6,0"/>
                            <TextBlock Text="Ready"
                                       FontSize="11.5"
                                       FontWeight="Normal"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>

                    <!-- Date -->
                    <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='MMM dd, yyyy'}"
                               FontSize="11.5"
                               FontWeight="Normal"
                               Foreground="{StaticResource TextTertiary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════
             ROW 1 · MAIN BODY
        ══════════════════════════════════ -->
        <Grid Grid.Row="1" Background="{StaticResource TertiaryBg}">

            <!-- Levitating card — centered -->
            <Border Style="{StaticResource PremiumCardStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="520">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Eyebrow badge row      -->
                        <RowDefinition Height="Auto"/>
                        <!-- Title                  -->
                        <RowDefinition Height="Auto"/>
                        <!-- Description            -->
                        <RowDefinition Height="Auto"/>
                        <!-- Divider                -->
                        <RowDefinition Height="Auto"/>
                        <!-- Field label            -->
                        <RowDefinition Height="Auto"/>
                        <!-- File input row         -->
                        <RowDefinition Height="Auto"/>
                        <!-- File hint              -->
                        <RowDefinition Height="24"/>
                        <!-- Spacer                 -->
                        <RowDefinition Height="Auto"/>
                        <!-- Generate button        -->
                        <RowDefinition Height="Auto"/>
                        <!-- Progress area          -->
                        <RowDefinition Height="Auto"/>
                        <!-- Success banner         -->
                    </Grid.RowDefinitions>

                    <!-- ── Eyebrow badge ── -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource EyebrowBadgeStyle}">
                            <TextBlock Text="Excel → TUDF"
                                       FontSize="10.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryAccent}"/>
                        </Border>

                        <!-- Decorative line after badge -->
                        <Border Grid.Column="1" Height="1"
                                Background="{StaticResource BorderBrush}"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0"/>
                    </Grid>

                    <!-- ── Title ── -->
                    <TextBlock Grid.Row="1"
                               Text="Generate output"
                               Style="{StaticResource DisplayTitleStyle}"
                               Margin="0,0,0,9"/>

                    <!-- ── Description ── -->
                    <TextBlock Grid.Row="2"
                               Style="{StaticResource BodyLargeStyle}"
                               TextWrapping="Wrap"
                               Text="Select an Excel template to generate the corresponding TUDF output file. The generated document will render in the same directory as the source file."/>

                    <!-- ── Divider ── -->
                    <Border Grid.Row="3" Style="{StaticResource DividerStyle}"/>

                    <!-- ── Field label ── -->
                    <TextBlock Grid.Row="4"
                               Style="{StaticResource LabelStyle}"
                               Margin="0,0,0,8">
                        <Run Text="SOURCE SPREADSHEET"/>
                    </TextBlock>

                    <!-- ── File path input + Browse button ── -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtInputFilePath"
                                 Grid.Column="0"
                                 Style="{StaticResource PremiumInputStyle}"
                                 IsReadOnly="True"
                                 Text="Select a file to begin..."
                                 ToolTip="Path to your source Excel spreadsheet"/>

                        <Button x:Name="btnBrowse"
                                Grid.Column="2"
                                Content="Browse Files"
                                Click="BtnBrowse_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Open file picker"/>
                    </Grid>

                    <!-- ── File hint ── -->
                    <TextBlock Grid.Row="6"
                               Margin="0,6,0,0"
                               FontSize="11.5"
                               Foreground="{StaticResource TextTertiary}"
                               Text="Accepts .xlsx and .xls formats"/>

                    <!-- Row 7: Spacer (Height=24 defined above) -->

                    <!-- ── Generate TUDF button (full width) ── -->
                    <Button x:Name="btnGenerate"
                            Grid.Row="8"
                            Content="Generate TUDF"
                            Click="BtnGenerate_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Stretch"
                            IsEnabled="False"/>

                    <!-- ── Progress area (hidden until generation starts) ── -->
                    <StackPanel x:Name="panelStatus"
                                Grid.Row="9"
                                Margin="0,16,0,0"
                                Visibility="Collapsed">

                        <!-- Progress bar track -->
                        <ProgressBar x:Name="pbProgress"
                                     Style="{StaticResource LiquidProgressBarStyle}"
                                     Minimum="0" Maximum="100" Value="0"
                                     Margin="0,0,0,0"/>

                        <!-- Step label + percentage row -->
                        <Grid Margin="0,6,0,0">
                            <TextBlock x:Name="txtStatus"
                                       FontSize="11.5"
                                       FontWeight="Normal"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Left">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Visibility, ElementName=panelStatus}" Value="Visible">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="pulseText">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0.45" To="1.0"
                                                                             Duration="0:0:0.8"
                                                                             AutoReverse="True"
                                                                             RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="pulseText"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock x:Name="txtProgressPct"
                                       FontSize="11.5"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource PrimaryAccent}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Success banner (hidden until done) ── -->
                    <Border x:Name="borderSuccess"
                            Grid.Row="10"
                            Style="{StaticResource SuccessBannerStyle}"
                            Margin="0,14,0,0"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Check icon circle -->
                            <Border Grid.Column="0"
                                    Width="30" Height="30"
                                    CornerRadius="15"
                                    Background="{StaticResource PrimaryAccent}"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.3"
                                                      ShadowDepth="2" Direction="270"
                                                      Color="{StaticResource PrimaryAccentColor}"/>
                                </Border.Effect>
                                <!-- Checkmark path -->
                                <Path Width="12" Height="12"
                                      Fill="#FFFFFF"
                                      Stretch="Uniform"
                                      Data="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>

                            <!-- Status text + file path -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0">
                                <TextBlock Text="PROCESSING COMPLETE"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryAccent}"
                                           Margin="0,0,0,2"/>
                                <TextBlock x:Name="txtOutputPath"
                                           FontSize="12.5"
                                           FontWeight="Normal"
                                           Foreground="{StaticResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Open File button -->
                            <Button x:Name="btnOpenFile"
                                    Grid.Column="2"
                                    Content="Open File"
                                    Click="BtnOpenFile_Click"
                                    Style="{StaticResource CompactPrimaryButtonStyle}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════
             ROW 2 · FOOTER BAR
        ══════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource FooterBarStyle}">
            <Grid Margin="24,0">

                <!-- Left: company name -->
                <TextBlock Style="{StaticResource FooterBrandStyle}"
                           Text="Three Star Infotech Pvt. Ltd."
                           VerticalAlignment="Center"/>

                <!-- Right: version pill -->
                <Border Style="{StaticResource VersionPillStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <TextBlock Text="v1.0.0"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextTertiary}"/>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>
