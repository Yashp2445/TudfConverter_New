<Window x:Class="TudfConverter.WpfUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TUDF Converter"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FC">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E2E6EF" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="32" Height="32" CornerRadius="8" Background="#1A56DB" Margin="0,0,12,0">
                        <TextBlock Text="TC" Foreground="White" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </Border>
                    <TextBlock Text="TUDF Converter" Foreground="#111827" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <TextBlock Text="MENU" Foreground="#9CA3AF" FontSize="10" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Margin="16,12,16,8"/>

                    <Border Background="#EBF0FF" BorderThickness="0">
                        <Grid Height="44">
                            <Border Width="3" HorizontalAlignment="Left" Background="#1A56DB"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                <TextBlock Text="📄" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Process File" Foreground="#1A56DB" FontSize="13"
                                           FontWeight="Medium" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="16,0,16,24">
                    <TextBlock Text="v1.1.0" Foreground="#9CA3AF" FontSize="11" FontFamily="Segoe UI"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E2E6EF" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <TextBlock Text="Process File" Foreground="#111827" FontSize="16" FontWeight="SemiBold"
                               FontFamily="Segoe UI" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F8F9FC">
                <StackPanel Margin="28,24,28,24">

                    <Border Background="White" CornerRadius="8" BorderBrush="#E2E6EF" BorderThickness="1"
                            Padding="24" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Opacity="0.06" ShadowDepth="2" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Upload Excel File" Foreground="#111827" FontSize="14"
                                       FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBlock Text="Select the UCRF-formatted Excel submission template (.xlsx)"
                                       Foreground="#6B7280" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,20"/>

                            <Border Height="110" CornerRadius="8" BorderBrush="#C8CEDC" BorderThickness="1.5"
                                    Background="#F8F9FC" Margin="0,0,0,16">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📁" FontSize="30" Foreground="#9CA3AF"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Click Browse to select your Excel file"
                                               Foreground="#6B7280" FontSize="12" FontFamily="Segoe UI"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Supported: .xlsx" Foreground="#9CA3AF" FontSize="11"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtInputFilePath" IsReadOnly="True"
                                         Background="White" Foreground="#111827"
                                         BorderBrush="#E2E6EF" BorderThickness="1.5"
                                         Padding="10,0" FontSize="12" FontFamily="Segoe UI"
                                         Height="38" Width="340" VerticalContentAlignment="Center"
                                         Margin="0,0,12,0">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="10,0"
                                                              VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                                <Button x:Name="btnBrowse" Content="Browse" Click="BtnBrowse_Click"
                                        Width="90" Height="38" Cursor="Hand"
                                        Foreground="#1A56DB" Background="White"
                                        BorderBrush="#1A56DB" BorderThickness="1.5"
                                        FontSize="13" FontWeight="Medium" FontFamily="Segoe UI">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#EBF0FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                        <Button x:Name="btnGenerate" Content="Generate TUDF" Click="BtnGenerate_Click"
                                IsEnabled="False" Width="160" Height="40" Cursor="Hand"
                                Foreground="White" Background="#1A56DB"
                                BorderThickness="0" FontSize="13" FontWeight="Medium"
                                FontFamily="Segoe UI">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6" Opacity="{TemplateBinding Opacity}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1444B8"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#C8CEDC"/>
                                            <Setter Property="Foreground" Value="#9CA3AF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <Border x:Name="panelStatus" Background="White" CornerRadius="8"
                            BorderBrush="#E2E6EF" BorderThickness="1" Padding="20"
                            Margin="0,0,0,20" Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Opacity="0.06" ShadowDepth="2" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock x:Name="txtStatus" Text="Processing..."
                                           Foreground="#111827" FontSize="13" FontFamily="Segoe UI"
                                           HorizontalAlignment="Left"/>
                            </Grid>
                            <ProgressBar x:Name="pbProgress" Minimum="0" Maximum="100" Value="0"
                                         Height="6" Background="#F0F2F7" Foreground="#1A56DB"
                                         BorderThickness="0">
                                <ProgressBar.Template>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                                    CornerRadius="3" HorizontalAlignment="Left"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>
                        </StackPanel>
                    </Border>

                    <Border x:Name="borderSuccess" Background="#DEF7EC" CornerRadius="8"
                            BorderBrush="#057A55" BorderThickness="1" Padding="20"
                            Margin="0,0,0,20" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="✅" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Processing Completed Successfully"
                                           Foreground="#057A55" FontSize="15" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>

                            <UniformGrid Columns="3" Margin="0,0,0,16">
                                <Border Background="White" CornerRadius="6" BorderBrush="#E2E6EF"
                                        BorderThickness="1" Padding="14,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock x:Name="txtTotalRows" Text="0" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="#111827" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Total Records" Foreground="#6B7280" FontSize="11"
                                                   FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="White" CornerRadius="6" BorderBrush="#057A55"
                                        BorderThickness="1,1,1,4" Padding="14,10" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock x:Name="txtAcceptedRows" Text="0" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="#057A55" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Accepted" Foreground="#6B7280" FontSize="11"
                                                   FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="White" CornerRadius="6" BorderBrush="#C81E1E"
                                        BorderThickness="1,1,1,4" Padding="14,10">
                                    <StackPanel>
                                        <TextBlock x:Name="txtRejectedRows" Text="0" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="#C81E1E" FontFamily="Segoe UI"/>
                                        <TextBlock Text="Rejected" Foreground="#6B7280" FontSize="11"
                                                   FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Background="White" CornerRadius="6" BorderBrush="#E2E6EF"
                                    BorderThickness="1" Padding="12" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📄" FontSize="22"
                                               Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Generated TUDF File" Foreground="#111827"
                                                   FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="txtOutputPath" Text="" Foreground="#6B7280"
                                                   FontSize="11" FontFamily="Segoe UI"
                                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnOpenFile" Content="Open Output Folder" Click="BtnOpenFile_Click"
                                        Height="36" Padding="16,0" Cursor="Hand"
                                        Foreground="White" Background="#1A56DB"
                                        BorderThickness="0" FontSize="12" FontWeight="Medium"
                                        FontFamily="Segoe UI">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1444B8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="White" BorderBrush="#E2E6EF" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#1A56DB" Margin="0,0,8,0"/>
                        <TextBlock x:Name="txtStatusBar" Text="Ready" Foreground="#6B7280"
                                   FontSize="11" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <TextBlock Text="v1.1.0" Foreground="#9CA3AF" FontSize="11" FontFamily="Segoe UI"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
