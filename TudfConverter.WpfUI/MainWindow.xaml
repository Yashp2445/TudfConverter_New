<Window x:Class="TudfConverter.WpfUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TudfConverter.WpfUI.Views"
        Title="TUDF Converter"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SecondaryBg}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PrimaryBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                    <Border Width="36" Height="36" CornerRadius="8" Background="{StaticResource PrimaryAccent}" Margin="0,0,12,0">
                        <TextBlock Text="TC" FontSize="14" FontWeight="Bold" Foreground="{StaticResource WhiteBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Sora"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TUDF Converter" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" FontFamily="Sora"/>
                        <TextBlock Text="Credit Bureau Tool" FontSize="12" Foreground="{StaticResource TextTertiary}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="16,24,16,0">
                    <TextBlock Text="WORKSPACE" Style="{StaticResource LabelStyle}" Margin="16,0,0,12"/>

                    <Button x:Name="btnNavProcess" Click="BtnNavProcess_Click" Height="44" HorizontalContentAlignment="Left" BorderThickness="0" Cursor="Hand" Background="{StaticResource SoftAccent}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6" Margin="0,0,0,4">
                                    <Grid>
                                        <Border x:Name="ActiveIndicator" Width="3" HorizontalAlignment="Left" Background="{StaticResource PrimaryAccent}" CornerRadius="2" Margin="0,8" Visibility="Visible"/>
                                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                                            <Path x:Name="Icon" Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,19H5V5H19V19M17,17H7V15H17V17M17,13H7V11H17V13M17,9H7V7H17V9Z" Fill="{StaticResource PrimaryAccent}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0"/>
                                            <TextBlock x:Name="Label" Text="Process File" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryAccent}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnNavValidation" Click="BtnNavValidation_Click" Height="44" HorizontalContentAlignment="Left" BorderThickness="0" Cursor="Hand" Background="Transparent">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <Grid>
                                        <Border x:Name="ActiveIndicator" Width="3" HorizontalAlignment="Left" Background="{StaticResource PrimaryAccent}" CornerRadius="2" Margin="0,8" Visibility="Collapsed"/>
                                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                                            <Path x:Name="Icon" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,19.93C7.05,19.43 4,16.05 4,12C4,7.95 7.05,4.57 11,4.07V19.93M13,4.07C16.95,4.57 20,7.95 20,12C20,16.05 16.95,19.43 13,19.93V4.07Z" Fill="{StaticResource TextTertiary}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0"/>
                                            <TextBlock x:Name="Label" Text="Validation Results" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="24,0,24,24">
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Three Star Infotech Pvt Ltd" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextTertiary}"/>
                    <TextBlock Text="v1.2.0" Foreground="{StaticResource TextTertiary}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="40,0">
                    <TextBlock x:Name="txtPageTitle" Text="Process Data" Style="{StaticResource DisplayTitleStyle}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TabControl x:Name="mainTabControl" Grid.Row="1" BorderThickness="0" Background="Transparent" Padding="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="40" MaxWidth="720" HorizontalAlignment="Left">

                            <Border Background="{StaticResource PrimaryBg}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="32" Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="Upload Source File" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" FontFamily="Sora" Margin="0,0,0,8"/>
                                    <TextBlock Text="Select the UCRF-formatted Excel submission template (.xlsx)" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,24"/>

                                    <Grid Height="140" Margin="0,0,0,24">
                                        <Rectangle StrokeDashArray="4 4" Stroke="{StaticResource BorderStrong}" Fill="{StaticResource SecondaryBg}" RadiusX="8" RadiusY="8" StrokeThickness="1.5"/>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M12,19L8,15H10.5V12H13.5V15H16L12,19Z" Fill="{StaticResource TextTertiary}" Width="32" Height="32" Stretch="Uniform" Margin="0,0,0,12"/>
                                            <TextBlock Text="Click Browse to select your Excel file" Foreground="{StaticResource TextSecondary}" FontSize="14" HorizontalAlignment="Center" FontWeight="Medium"/>
                                            <TextBlock Text="Supported formats: .xlsx" Foreground="{StaticResource TextTertiary}" FontSize="12" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtInputFilePath" Grid.Column="0" IsReadOnly="True" Style="{StaticResource PremiumInputStyle}" Margin="0,0,16,0"/>
                                        <Button x:Name="btnBrowse" Grid.Column="1" Content="Browse..." Click="BtnBrowse_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Button x:Name="btnGenerate" Content="Generate TUDF" Click="BtnGenerate_Click" IsEnabled="False" Style="{StaticResource PrimaryButtonStyle}" Width="180"/>
                            </StackPanel>

                            <Border x:Name="panelStatus" Background="{StaticResource PrimaryBg}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,24" Visibility="Collapsed" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock x:Name="txtStatus" Text="Initializing processing engine..." Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="Medium" HorizontalAlignment="Left"/>
                                        <TextBlock x:Name="txtProgressPercent" Text="{Binding ElementName=pbProgress, Path=Value, StringFormat={}{0:0}%}" Foreground="{StaticResource TextSecondary}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <ProgressBar x:Name="pbProgress" Minimum="0" Maximum="100" Value="0" Style="{StaticResource LiquidProgressBarStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="borderSuccess" Background="{StaticResource PrimaryBg}" CornerRadius="12" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1" Padding="32" Margin="0,0,0,24" Visibility="Collapsed" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource SuccessBg}" Margin="0,0,12,0">
                                            <Path Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" Fill="{StaticResource SuccessBrush}" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Processing Completed Successfully" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" FontFamily="Sora" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Grid Margin="0,0,0,32">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="{StaticResource TertiaryBg}" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="TOTAL RECORDS" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                                                <TextBlock x:Name="txtTotalRows" Text="0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="{StaticResource SuccessBg}" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="ACCEPTED" Style="{StaticResource LabelStyle}" Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,6"/>
                                                <TextBlock x:Name="txtAcceptedRows" Text="0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Background="#FEF2F2" CornerRadius="8" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="REJECTED" Style="{StaticResource LabelStyle}" Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,6"/>
                                                <TextBlock x:Name="txtRejectedRows" Text="0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Background="{StaticResource SecondaryBg}" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V13H11V20H18M12,20V15H17V20H12Z" Fill="{StaticResource TextSecondary}" Width="24" Height="24" Stretch="Uniform" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Generated TUDF File" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <TextBlock x:Name="txtOutputPath" Text="" Foreground="{StaticResource TextSecondary}" FontSize="13" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="btnOpenFile" Content="Open Output Folder" Click="BtnOpenFile_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                                        <Button x:Name="btnViewErrors" Content="Review Issues" Click="BtnViewErrors_Click" Margin="16,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Visibility="Collapsed"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="validationTab" IsEnabled="False">
                    <views:ValidationResultsView x:Name="validationResultsView"/>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Background="{StaticResource PrimaryBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="24,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtStatusBar" Text="System Ready" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>