<UserControl x:Class="TudfConverter.WpfUI.Views.ValidationResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SecondaryBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="40,32,40,24">
            <TextBlock Text="Validation Summary" FontSize="16" FontWeight="SemiBold" FontFamily="Sora" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" HorizontalAlignment="Left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBox Style="{StaticResource PremiumInputStyle}" Width="260" Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}" Tag="Search by ID or field..."/>
                <ComboBox Width="180" Margin="16,0,0,0" Height="38" Background="{StaticResource PrimaryBg}" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderStrong}" SelectedValue="{Binding SelectedOutcomeFilter}" SelectedIndex="0">
                    <ComboBoxItem Content="All Results"/>
                    <ComboBoxItem Content="Rejected Records"/>
                    <ComboBoxItem Content="Field Level Errors"/>
                </ComboBox>
                <Button Content="Export CSV" Margin="16,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportCsvCommand}"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="1" Margin="40,0,40,24">
            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="6" Padding="16,8" Margin="0,0,16,0">
                <TextBlock Foreground="{StaticResource ErrorBrush}" FontSize="13" FontWeight="SemiBold" Text="{Binding RejectedRowCount, StringFormat='{}{0} Rejected'}"/>
            </Border>
            <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="6" Padding="16,8" Margin="0,0,16,0">
                <TextBlock Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" Text="{Binding FieldErrorCount, StringFormat='{}{0} Field Errors'}"/>
            </Border>
            <Border Background="{StaticResource PrimaryBg}" BorderBrush="{StaticResource BorderStrong}" BorderThickness="1" CornerRadius="6" Padding="16,8">
                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Text="{Binding TotalIssueCount, StringFormat='{}{0} Total Issues'}"/>
            </Border>
        </WrapPanel>

        <Border Grid.Row="2" Background="{StaticResource PrimaryBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1">
            <DataGrid x:Name="dgErrors"
                      ItemsSource="{Binding FilteredErrors}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Background="Transparent"
                      RowBackground="{StaticResource PrimaryBg}"
                      AlternatingRowBackground="{StaticResource SecondaryBg}"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      RowHeight="52"
                      FontSize="13">

                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource SoftAccentColor}"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>
                </DataGrid.Resources>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource TertiaryBg}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
                        <Setter Property="Height" Value="48"/>
                        <Setter Property="Padding" Value="24,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Line" Binding="{Binding RowNumber}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Segment" Binding="{Binding SegmentTag}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Margin" Value="24,0,0,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Code" Binding="{Binding ErrorCode}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="JetBrains Mono, Consolas, monospace"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Field" Binding="{Binding FieldName}" Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Validation Message" Binding="{Binding ErrorMessage}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="3" Margin="40,16">
            <TextBlock Text="{Binding FilteredCount, StringFormat='Showing {0} records'}" Foreground="{StaticResource TextTertiary}" FontSize="13" DockPanel.Dock="Left"/>
            <TextBlock Text="Records marked as rejected are excluded from output." Foreground="{StaticResource TextTertiary}" FontSize="13" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</UserControl>